# ── Embedding backend ─────────────────────────────────────────────────────────
# "local"  → sentence-transformers model, runs on CPU/GPU, no API cost
# "openai" → OpenAI Embeddings API, requires OPENAI_API_KEY
EMBED_BACKEND=local

# HuggingFace model name (used when EMBED_BACKEND=local and EMBEDDER_MODEL_PATH is empty)
# Downloaded and cached from HF Hub on first run.
EMBED_MODEL=all-MiniLM-L6-v2

# Absolute or relative path to a fine-tuned sentence-transformers model directory.
# Leave empty → EMBED_MODEL is loaded from HF Hub.
# Set to ./data/models/domain_adapted_model to use the CVE fine-tuned model.
# FAIL-LOUD: if this is set but the directory does not exist, the server refuses to start.
EMBEDDER_MODEL_PATH=

# Multiplier applied to raw embedding vectors before sending to arro-server.
# Vectors are never L2-normalised — arro-server contract requires raw scaled vectors.
# Default 1.0 means no scaling (raw vector).
# Changing this after an index is built will corrupt search results.
EMBED_SCALE_FACTOR=1.0

# Required only when EMBED_BACKEND=openai
OPENAI_API_KEY=

# ── arro-server ──────────────────────────────────────────────────────────────
ARRO_SERVER_URL=http://localhost:8001
ARRO_SERVER_DATASET_ID=cve/embeddings
# tau in [0,1]: 0.42=spectral dominant, 0.70=hybrid, 1.00=cosine equivalent
ARRO_SERVER_SEARCH_TAU=0.42

# ── Document store ────────────────────────────────────────────────────────
# STORE_DB_PATH=./data/documents.sqlite

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
